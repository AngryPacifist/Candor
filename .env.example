# ── TxLINE (data subscription) ──
TXLINE_API_ORIGIN=            # https://txline.txodds.com (mainnet)
TXLINE_API_TOKEN=             # activated X-Api-Token (on-chain subscribe + /api/token/activate)
TXLINE_JWT=                   # guest JWT bootstrap; the client re-issues via /auth/guest/start

# ── Solana ──
SOLANA_RPC_URL=               # mainnet RPC (Helius recommended)
SOLANA_DEVNET_RPC_URL=        # devnet RPC (only used by dev sanity scripts)
AGENT_KEYPAIR_PATH=.secrets/agent-keypair.json   # NEVER commit the keypair

# ── Database (Neon Postgres) ──
DATABASE_URL=

# ── App ──
PUBLIC_URL=                   # dashboard URL once deployed
